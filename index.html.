function showResult(data) {
  document.getElementById('analyzingState').style.display = 'none';
  const rs = document.getElementById('resultState');
  rs.style.display = 'flex';

  // Title
  document.getElementById('diagTitle').textContent = data.titulo;
  document.getElementById('diagSub').textContent = data.subtitulo;

  // Score arc
  const score = data.potencial || 87;
  document.getElementById('scoreNum').textContent = score;
  const circ = 2 * Math.PI * 30;
  const arc = (score / 100) * circ;
  setTimeout(() => {
    document.getElementById('scoreArc').setAttribute('stroke-dasharray', `${arc} ${circ}`);
  }, 300);

  // Metrics
  const mg = document.getElementById('metricsGrid');
  mg.innerHTML = '';
  (data.metricas || []).forEach(m => {
    const div = document.createElement('div');
    div.className = 'metric-card';
    div.innerHTML = `<div class="metric-val">${m.valor}</div><div class="metric-label">${m.nombre}</div><div class="metric-bar"><div class="metric-fill" style="width:0%" data-w="${m.porcentaje}%"></div></div>`;
    mg.appendChild(div);
  });
  setTimeout(() => {
    document.querySelectorAll('.metric-fill').forEach(f => f.style.width = f.dataset.w);
  }, 400);

  // AI Text
  document.getElementById('aiText').innerHTML = data.diagnostico || '';

  // Recs
  const rl = document.getElementById('recList');
  rl.innerHTML = '';
  (data.tratamientos || []).forEach(t => {
    const pClass = t.prioridad === 'Alta' ? 'priority-high' : t.prioridad === 'Media' ? 'priority-med' : 'priority-opt';
    const div = document.createElement('div');
    div.className = 'rec-item';
    div.innerHTML = `
      <div class="rec-icon" style="background:${t.colorIcon || 'rgba(37,99,235,0.15)'}">${t.icono}</div>
      <div class="rec-info">
        <div class="rec-name">${t.nombre}</div>
        <div class="rec-desc">${t.descripcion}</div>
      </div>
      <div class="rec-priority ${pClass}">${t.prioridad}</div>
    `;
    rl.appendChild(div);
  });

  // Face zones overlay
  const overlay = document.getElementById('faceOverlay');
  overlay.innerHTML = '';
  (data.zonas || []).forEach((z, i) => {
    const marker = document.createElement('div');
    marker.className = 'zone-marker';
    marker.style.cssText = `top:${z.top};left:${z.left};animation-delay:${i*0.2+0.5}s;`;
    marker.innerHTML = `<div class="zone-dot" style="background:${z.color};color:${z.color};"></div><div class="zone-label" style="color:${z.color};">${z.nombre}</div>`;
    overlay.appendChild(marker);
  });
}

