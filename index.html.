<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Escáner Facial IA — HostUp</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --blue:#2563EB;--blue-dark:#1D4ED8;--blue-light:#EFF6FF;--blue-glow:rgba(37,99,235,0.25);
  --sky:#7DD3FC;--white:#FFFFFF;--dark:#0F172A;--mid:#475569;--border:#E2E8F0;--gray:#F8FAFC;
}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--white);min-height:100vh;overflow-x:hidden;}

/* BG */
.bg-mesh{position:fixed;inset:0;z-index:0;background:radial-gradient(ellipse 80% 50% at 20% 20%,rgba(37,99,235,0.12) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 80%,rgba(125,211,252,0.08) 0%,transparent 60%),#0F172A;pointer-events:none;}

/* HEADER */
header{position:relative;z-index:10;padding:20px 28px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.06);}
.logo{font-family:‘Syne’,sans-serif;font-weight:800;font-size:18px;display:flex;align-items:center;gap:10px;}
.logo-icon{width:34px;height:34px;background:var(–blue);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;}
.header-badge{font-size:11px;font-weight:500;color:var(–sky);background:rgba(125,211,252,0.1);border:1px solid rgba(125,211,252,0.2);padding:5px 12px;border-radius:100px;letter-spacing:1px;text-transform:uppercase;}

/* MAIN LAYOUT */
.app{position:relative;z-index:1;max-width:900px;margin:0 auto;padding:32px 20px 60px;}

/* TITLE */
.app-title{text-align:center;margin-bottom:36px;}
.app-title h1{font-family:‘Syne’,sans-serif;font-size:clamp(28px,5vw,46px);font-weight:800;line-height:1.05;letter-spacing:-1.5px;margin-bottom:12px;}
.app-title h1 span{color:var(–sky);}
.app-title p{font-size:15px;color:rgba(255,255,255,0.5);font-weight:300;max-width:460px;margin:0 auto;}

/* TREATMENT SELECTOR */
.treatment-bar{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:32px;}
.t-pill{
font-family:‘DM Sans’,sans-serif;font-size:13px;font-weight:500;
padding:9px 18px;border-radius:100px;cursor:pointer;
border:1.5px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.55);
background:rgba(255,255,255,0.04);transition:all 0.2s;
}
.t-pill:hover{border-color:var(–blue);color:white;}
.t-pill.active{background:var(–blue);border-color:var(–blue);color:white;box-shadow:0 0 20px rgba(37,99,235,0.4);}

/* MAIN CARD */
.main-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:24px;overflow:hidden;backdrop-filter:blur(10px);}

/* UPLOAD ZONE */
.upload-zone{
min-height:340px;display:flex;flex-direction:column;align-items:center;justify-content:center;
cursor:pointer;position:relative;transition:all 0.3s;
border-bottom:1px solid rgba(255,255,255,0.06);
}
.upload-zone.dragover{background:rgba(37,99,235,0.08);border-color:var(–blue);}
.upload-zone input{display:none;}

.upload-idle{display:flex;flex-direction:column;align-items:center;gap:16px;padding:40px;}
.upload-circle{
width:100px;height:100px;border-radius:50%;
border:2px dashed rgba(125,211,252,0.3);
display:flex;align-items:center;justify-content:center;
position:relative;animation:rotateDash 12s linear infinite;
}
@keyframes rotateDash{to{transform:rotate(360deg);}}
.upload-circle-inner{
width:80px;height:80px;border-radius:50%;
background:rgba(37,99,235,0.15);
display:flex;align-items:center;justify-content:center;
font-size:32px;
animation:rotateDash 12s linear infinite reverse;
}
.upload-title{font-family:‘Syne’,sans-serif;font-size:18px;font-weight:700;text-align:center;}
.upload-sub{font-size:13px;color:rgba(255,255,255,0.4);text-align:center;max-width:280px;line-height:1.6;}
.upload-btn{background:var(–blue);color:white;border:none;font-family:‘Syne’,sans-serif;font-size:14px;font-weight:700;padding:13px 28px;border-radius:10px;cursor:pointer;transition:all 0.2s;margin-top:4px;}
.upload-btn:hover{background:var(–blue-dark);transform:translateY(-1px);}

/* PRIVACY NOTE */
.privacy{display:flex;align-items:center;gap:6px;font-size:11px;color:rgba(255,255,255,0.25);margin-top:8px;}
.privacy::before{content:‘🔒’;}

/* ANALYZING STATE */
.analyzing-state{display:none;flex-direction:column;align-items:center;justify-content:center;padding:48px;gap:24px;min-height:340px;}
.scan-ring{position:relative;width:140px;height:140px;}
.scan-ring-outer{position:absolute;inset:0;border-radius:50%;border:2px solid rgba(37,99,235,0.2);animation:scanPulse 2s ease-in-out infinite;}
.scan-ring-mid{position:absolute;inset:12px;border-radius:50%;border:2px solid rgba(37,99,235,0.4);animation:scanPulse 2s 0.3s ease-in-out infinite;}
.scan-ring-inner{position:absolute;inset:24px;border-radius:50%;border:2px solid var(–blue);animation:rotateDash 2s linear infinite;}
.scan-face{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:42px;}
@keyframes scanPulse{0%,100%{transform:scale(1);opacity:0.5;}50%{transform:scale(1.08);opacity:1;}}
.scan-steps{width:100%;max-width:320px;display:flex;flex-direction:column;gap:10px;}
.scan-step{display:flex;align-items:center;gap:12px;font-size:13px;color:rgba(255,255,255,0.4);transition:all 0.4s;}
.scan-step.active{color:white;}
.scan-step.done{color:var(–sky);}
.scan-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.15);flex-shrink:0;transition:all 0.4s;}
.scan-step.active .scan-dot{background:var(–blue);box-shadow:0 0 10px var(–blue);animation:dotPulse 1s infinite;}
.scan-step.done .scan-dot{background:var(–sky);}
@keyframes dotPulse{0%,100%{box-shadow:0 0 6px var(–blue);}50%{box-shadow:0 0 16px var(–blue),0 0 30px var(–blue);}}
.scan-bar-wrap{width:100%;max-width:320px;height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;}
.scan-bar{height:100%;background:linear-gradient(to right,var(–blue),var(–sky));border-radius:2px;width:0%;transition:width 0.5s ease;}

/* RESULT STATE */
.result-state{display:none;flex-direction:column;}

/* PHOTO + OVERLAY */
.photo-analysis{position:relative;background:#000;min-height:280px;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.patient-photo{width:100%;max-height:380px;object-fit:cover;object-position:top;display:block;opacity:0.85;}

/* FACE DETECTION OVERLAY */
.face-overlay{position:absolute;inset:0;pointer-events:none;}
.face-box{position:absolute;border:1.5px solid rgba(37,99,235,0.7);border-radius:4px;animation:boxFadeIn 0.5s ease forwards;}
@keyframes boxFadeIn{from{opacity:0;transform:scale(0.95);}to{opacity:1;transform:scale(1);}}

.zone-marker{position:absolute;display:flex;flex-direction:column;align-items:center;gap:3px;animation:markerIn 0.4s ease forwards;opacity:0;}
@keyframes markerIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.zone-dot{width:10px;height:10px;border-radius:50%;border:2px solid white;position:relative;}
.zone-dot::after{content:’’;position:absolute;inset:-4px;border-radius:50%;animation:zonePulse 2s infinite;}
@keyframes zonePulse{0%,100%{box-shadow:0 0 0 0 currentColor;}50%{box-shadow:0 0 0 6px transparent;}}
.zone-label{font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;white-space:nowrap;background:rgba(0,0,0,0.7);padding:2px 6px;border-radius:4px;}

.scan-line-anim{position:absolute;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,rgba(37,99,235,0.8),transparent);animation:scanLineMove 2s ease-in-out 3;top:0;}
@keyframes scanLineMove{0%{top:0;opacity:1;}100%{top:100%;opacity:0;}}

.analysis-badge{position:absolute;top:12px;right:12px;background:rgba(0,0,0,0.75);backdrop-filter:blur(8px);border:1px solid rgba(37,99,235,0.4);border-radius:8px;padding:8px 12px;font-size:11px;font-weight:700;color:var(–sky);letter-spacing:1px;display:flex;align-items:center;gap:6px;}
.analysis-badge::before{content:’’;width:6px;height:6px;border-radius:50%;background:#22C55E;box-shadow:0 0 8px #22C55E;}

/* DIAGNOSIS PANEL */
.diagnosis-panel{padding:28px;}

.patient-info-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:gap;}
.patient-score{display:flex;flex-direction:column;align-items:center;gap:4px;}
.score-ring{position:relative;width:72px;height:72px;}
.score-ring svg{transform:rotate(-90deg);}
.score-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:‘Syne’,sans-serif;font-size:18px;font-weight:800;color:var(–sky);}
.score-label{font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:1px;text-transform:uppercase;}

.diagnosis-title{font-family:‘Syne’,sans-serif;font-size:20px;font-weight:800;margin-bottom:6px;line-height:1.2;}
.diagnosis-subtitle{font-size:13px;color:rgba(255,255,255,0.5);font-weight:300;margin-bottom:20px;}

/* SKIN METRICS */
.metrics-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px;}
.metric-card{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:14px 12px;text-align:center;}
.metric-val{font-family:‘Syne’,sans-serif;font-size:22px;font-weight:800;color:var(–sky);}
.metric-label{font-size:10px;color:rgba(255,255,255,0.35);margin-top:3px;letter-spacing:0.5px;}
.metric-bar{height:3px;background:rgba(255,255,255,0.08);border-radius:2px;margin-top:8px;overflow:hidden;}
.metric-fill{height:100%;border-radius:2px;background:linear-gradient(to right,var(–blue),var(–sky));transition:width 1.5s ease;}

/* TREATMENT RECOMMENDATIONS */
.recs-title{font-family:‘Syne’,sans-serif;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,0.35);margin-bottom:14px;}
.rec-list{display:flex;flex-direction:column;gap:10px;margin-bottom:24px;}
.rec-item{
background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);
border-radius:14px;padding:16px;display:flex;align-items:center;gap:14px;
transition:all 0.2s;cursor:default;
}
.rec-item:hover{background:rgba(37,99,235,0.08);border-color:rgba(37,99,235,0.3);}
.rec-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.rec-info{flex:1;}
.rec-name{font-family:‘Syne’,sans-serif;font-size:14px;font-weight:700;margin-bottom:3px;}
.rec-desc{font-size:12px;color:rgba(255,255,255,0.45);line-height:1.5;}
.rec-priority{font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;letter-spacing:0.5px;flex-shrink:0;}
.priority-high{background:rgba(239,68,68,0.15);color:#FCA5A5;border:1px solid rgba(239,68,68,0.2);}
.priority-med{background:rgba(234,179,8,0.15);color:#FDE68A;border:1px solid rgba(234,179,8,0.2);}
.priority-opt{background:rgba(34,197,94,0.15);color:#86EFAC;border:1px solid rgba(34,197,94,0.2);}

/* AI ANALYSIS TEXT */
.ai-analysis{background:linear-gradient(135deg,rgba(37,99,235,0.08),rgba(125,211,252,0.05));border:1px solid rgba(37,99,235,0.2);border-radius:16px;padding:20px;margin-bottom:24px;}
.ai-analysis-header{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
.ai-chip{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(–sky);background:rgba(125,211,252,0.1);padding:4px 10px;border-radius:100px;border:1px solid rgba(125,211,252,0.2);}
.ai-text{font-size:14px;line-height:1.8;color:rgba(255,255,255,0.75);font-weight:300;}
.ai-text strong{color:white;font-weight:500;}

/* LEAD CAPTURE */
.lead-form{background:rgba(37,99,235,0.06);border:1px solid rgba(37,99,235,0.2);border-radius:16px;padding:24px;}
.lead-form-title{font-family:‘Syne’,sans-serif;font-size:16px;font-weight:800;margin-bottom:4px;}
.lead-form-sub{font-size:13px;color:rgba(255,255,255,0.4);margin-bottom:18px;font-weight:300;}
.form-row{display:flex;gap:10px;flex-wrap:wrap;}
.form-input{
flex:1;min-width:180px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);
border-radius:10px;padding:13px 16px;font-size:14px;color:white;outline:none;
font-family:‘DM Sans’,sans-serif;transition:border-color 0.2s;
}
.form-input::placeholder{color:rgba(255,255,255,0.25);}
.form-input:focus{border-color:var(–blue);background:rgba(37,99,235,0.08);}
.form-submit{
background:var(–blue);color:white;border:none;
font-family:‘Syne’,sans-serif;font-size:14px;font-weight:800;
padding:13px 24px;border-radius:10px;cursor:pointer;
transition:all 0.2s;white-space:nowrap;
box-shadow:0 4px 20px rgba(37,99,235,0.4);
}
.form-submit:hover{background:var(–blue-dark);transform:translateY(-1px);}

/* SUCCESS */
.success-state{display:none;flex-direction:column;align-items:center;gap:16px;padding:40px;text-align:center;}
.success-icon{width:72px;height:72px;border-radius:50%;background:rgba(34,197,94,0.15);border:2px solid rgba(34,197,94,0.3);display:flex;align-items:center;justify-content:center;font-size:32px;animation:successPop 0.5s cubic-bezier(.22,1,.36,1) forwards;}
@keyframes successPop{from{transform:scale(0);}to{transform:scale(1);}}
.success-title{font-family:‘Syne’,sans-serif;font-size:22px;font-weight:800;}
.success-sub{font-size:14px;color:rgba(255,255,255,0.5);max-width:320px;line-height:1.7;}
.success-wa{
display:inline-flex;align-items:center;gap:10px;
background:#25D366;color:white;text-decoration:none;
font-family:‘Syne’,sans-serif;font-size:14px;font-weight:800;
padding:14px 28px;border-radius:12px;
box-shadow:0 4px 20px rgba(37,211,102,0.35);
transition:all 0.2s;
}
.success-wa:hover{background:#1fb858;transform:translateY(-2px);}

/* RESET */
.reset-btn{background:none;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);font-family:‘DM Sans’,sans-serif;font-size:12px;padding:8px 16px;border-radius:8px;cursor:pointer;transition:all 0.2s;margin-top:4px;}
.reset-btn:hover{border-color:rgba(255,255,255,0.3);color:white;}

/* POWERED BY */
.powered{text-align:center;margin-top:32px;font-size:11px;color:rgba(255,255,255,0.2);display:flex;align-items:center;gap:6px;justify-content:center;}
.powered strong{color:rgba(255,255,255,0.4);}

/* RESPONSIVE */
@media(max-width:500px){
.metrics-grid{grid-template-columns:1fr 1fr;}
.form-row{flex-direction:column;}
.patient-info-row{flex-direction:column;gap:16px;align-items:flex-start;}
}
</style>

</head>
